{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "formatter": {
    "indentStyle": "space"
  },
  "linter": {
    "rules": {
      "style": {
        "noDefaultExport": "on",
        "noRestrictedGlobals": "error",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": ["./**", "../**"],
                "message": "Use @ alias for source files"
              },
              {
                "group": ["@/**", "!@/**/*.*"],
                "message": "Use file extensions for source files"
              }
            ]
          }
        },
        "useComponentExportOnlyModules": "error"
      },
      "correctness": {
        "noUndeclaredDependencies": "on",
        "noUndeclaredVariables": "on",
        "noUnresolvedImports": "off",
        "useImportExtensions": "on"
      },
      "nursery": {
        "useSortedClasses": "on"
      }
    }
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    }
  }
}
